input::placeholder,textarea::placeholder{color:#4a4a6a}
select option{background:#12121e;color:#e2e8f0}
textarea{resize:vertical}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:#0a0a0f}
::-webkit-scrollbar-thumb{background:linear-gradient(#7b89ff,#a78bfa);border-radius:4px}
@keyframes fadeSlide{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(1.4)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
@media(max-width:768px){
  .dn-mob{display:none!important}
  .ds-mob{display:flex!important}
  .grid2{grid-template-columns:1fr!important}
  .hero-h1{font-size:clamp(2rem,9vw,3rem)!important}
