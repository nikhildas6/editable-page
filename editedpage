.chov{transition:all .28s ease}
.chov:hover{transform:translateY(-5px);box-shadow:0 20px 48px rgba(123,137,255,.2)}
a{text-decoration:none;color:inherit}
input,textarea,select{width:100%;padding:13px 16px;border:1.5px solid #2a2a40;border-radius:12px;font-size:15px;font-family:'Inter',sans-serif;background:#12121e;color:#e2e8f0;outline:none;transition:border-color .25s,box-shadow .25s}
